<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartStudy Hub</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar glass">
        <a href="/" class="logo"> SmartStudy Hub</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <% if (isLoggedIn) { %>
                <a href="/dashboard">Dashboard</a>
                <a href="/browse">Browse</a>
                <a href="/leaderboard">Leaderboard</a>
                <a href="/profile">Profile</a>
                <a href="/logout">Logout</a>
            <% } else { %>
                <a href="/login">Login</a>
                <a href="/register">Register</a>
            <% } %>
        </div>
    </nav>

    <div class="container">
        <div class="hero glass">
            <h1>Elevate Your Learning Journey </h1>
            <p>SmartStudy Hub is a gamified classroom resource sharing platform. Earn points, track streaks, and discover top-rated materials.</p>
            
            <!-- Features with Images -->
            <div class="features" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin: 40px 0;">
                
                <!-- Feature 1: Smart Recommendations -->
                <div class="feature-card glass" style="overflow: hidden; border-radius: 12px; transition: transform 0.3s ease;">
                    <div style="width: 100%; height: 180px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; font-size: 60px;">
                        🧠
                    </div>
                    <div style="padding: 20px;">
                        <h3 style="margin: 10px 0; color: #222;">💡 Smart Recommendations</h3>
                        <p style="color: #666; margin: 0;">Get personalized resource suggestions based on your study habits.</p>
                    </div>
                </div>

                <!-- Feature 2: Gamification & Rewards -->
                <div class="feature-card glass" style="overflow: hidden; border-radius: 12px; transition: transform 0.3s ease;">
                    <div style="width: 100%; height: 180px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); display: flex; align-items: center; justify-content: center; font-size: 60px;">
                        🏆
                    </div>
                    <div style="padding: 20px;">
                        <h3 style="margin: 10px 0; color: #222;">🎮 Gamification & Rewards</h3>
                        <p style="color: #666; margin: 0;">Earn points, climb the leaderboard, and showcase your knowledge.</p>
                    </div>
                </div>

                <!-- Feature 3: Study Streak -->
                <div class="feature-card glass" style="overflow: hidden; border-radius: 12px; transition: transform 0.3s ease;">
                    <div style="width: 100%; height: 180px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); display: flex; align-items: center; justify-content: center; font-size: 60px;">
                        🔥
                    </div>
                    <div style="padding: 20px;">
                        <h3 style="margin: 10px 0; color: #222;">⚡ Study Streak</h3>
                        <p style="color: #666; margin: 0;">Build daily learning habits with our interactive streak tracker.</p>
                    </div>
                </div>

                <!-- Feature 4: Verified Resources -->
                <div class="feature-card glass" style="overflow: hidden; border-radius: 12px; transition: transform 0.3s ease;">
                    <div style="width: 100%; height: 180px; background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); display: flex; align-items: center; justify-content: center; font-size: 60px;">
                        ✅
                    </div>
                    <div style="padding: 20px;">
                        <h3 style="margin: 10px 0; color: #222;">📚 Verified Resources</h3>
                        <p style="color: #666; margin: 0;">Access high-quality, teacher-approved study materials.</p>
                    </div>
                </div>
            </div>

            <!-- MCQ Testing Feature -->
            <div style="margin: 40px 0; padding: 30px; background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 193, 7, 0.1) 100%); border-radius: 12px; border: 2px solid rgba(255, 107, 107, 0.3); text-align: center;">
                <div style="font-size: 50px; margin-bottom: 10px;">📝✨</div>
                <h2 style="color: #222; margin: 10px 0;">Interactive MCQ Testing</h2>
                <p style="color: #666; font-size: 16px;">Teachers create engaging multiple-choice quizzes, students test their knowledge and earn rewards. Make learning interactive and fun!</p>
            </div>

            <!-- Search Feature Highlight -->
            <div style="margin: 40px 0; padding: 30px; background: linear-gradient(135deg, rgba(100, 200, 255, 0.1) 0%, rgba(150, 100, 255, 0.1) 100%); border-radius: 12px; border: 2px solid rgba(100, 200, 255, 0.3); text-align: center;">
                <div style="font-size: 50px; margin-bottom: 10px;">🔍📚</div>
                <h2 style="color: #222; margin: 10px 0;">Advanced Search & Filtering</h2>
                <p style="color: #666; font-size: 16px;">Find exactly what you need! Search by title, filter by semester, and discover resources by subject. Your knowledge, perfectly organized.</p>
            </div>
            
            <% if (!isLoggedIn) { %>
                <div class="buttons mt-4">
                    <a href="/register" class="btn btn-primary">Get Started Now </a>
                    <a href="/login" class="btn">Login to Account</a>
                </div>
            <% } else { %>
                <div class="buttons mt-4">
                    <a href="/dashboard" class="btn btn-primary">Go to Dashboard →</a>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>