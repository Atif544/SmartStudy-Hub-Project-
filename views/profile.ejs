<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - SmartStudy Hub</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar glass">
        <a href="/" class="logo"> SmartStudy Hub</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Dashboard</a>
            <a href="/browse">Browse</a>
            <a href="/leaderboard">Leaderboard</a>
            <a href="/profile">Profile</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <div class="container" style="max-width: 600px;">
        <div class="card glass" style="padding: 40px;">
            <div style="text-align: center; margin-bottom: 30px;">
                <div style="font-size: 64px; margin-bottom: 10px;">👤</div>
                <h2 style="margin: 0; color: #111;">My Profile</h2>
                <div style="margin-top: 5px; color: #555; font-weight: 500;"><%= user.name %> | <%= user.email %> | <span style="text-transform: capitalize;"><%= user.role %></span></div>
            </div>
            
            <!-- Insights Dashboard -->
            <h3 style="margin-bottom: 15px; color: #333; border-bottom: 2px solid rgba(0,0,0,0.1); padding-bottom: 5px;">📊 Contribution Insights</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px;">
                <div class="glass" style="padding: 15px; text-align: center; background: rgba(51, 154, 240, 0.1); border-color: rgba(51, 154, 240, 0.3);">
                    <div style="font-size: 28px; font-weight: 700; color: #1c7ed6;"><%= typeof insights !== 'undefined' ? insights.uploads : 0 %></div>
                    <div style="font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase;">Total Uploads</div>
                </div>
                <div class="glass" style="padding: 15px; text-align: center; background: rgba(81, 207, 102, 0.1); border-color: rgba(81, 207, 102, 0.3);">
                    <div style="font-size: 28px; font-weight: 700; color: #2b8a3e;"><%= typeof insights !== 'undefined' ? insights.downloads : 0 %></div>
                    <div style="font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase;">Downloads Triggered</div>
                </div>
                <div class="glass" style="padding: 15px; text-align: center; background: rgba(255, 107, 107, 0.1); border-color: rgba(255, 107, 107, 0.3);">
                    <div style="font-size: 28px; font-weight: 700; color: #e03131;"><%= typeof insights !== 'undefined' ? insights.likes : 0 %></div>
                    <div style="font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase;">Likes Received</div>
                </div>
                <div class="glass" style="padding: 15px; text-align: center; background: rgba(255, 212, 59, 0.1); border-color: rgba(255, 212, 59, 0.4);">
                    <div style="font-size: 28px; font-weight: 700; color: #b8860b;">#<%= typeof insights !== 'undefined' ? insights.rank : 1 %></div>
                    <div style="font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase;">Global Rank</div>
                </div>
            </div>
            
            <h3 style="margin-bottom: 15px; color: #333; border-bottom: 2px solid rgba(0,0,0,0.1); padding-bottom: 5px;">🔥 Gamification Status</h3>
            <div class="profile-info" style="display: flex; flex-direction: column; gap: 15px; font-size: 16px;">
                <div class="glass" style="padding: 15px 20px; display: flex; justify-content: space-between; background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(255,215,0,0.2)); border-color: rgba(255,215,0,0.5);">
                    <strong style="color: #555;">� Points:</strong> 
                    <span style="color: #b8860b; font-weight: 700; font-size: 18px;"><%= user.points %></span>
                </div>
                <div class="glass" style="padding: 15px 20px; display: flex; justify-content: space-between; background: linear-gradient(135deg, rgba(255,107,107,0.1), rgba(255,107,107,0.2)); border-color: rgba(255,107,107,0.5);">
                    <strong style="color: #555;"> Study Streak:</strong> 
                    <span style="color: #e03131; font-weight: 700; font-size: 18px;"><%= user.streak %> days</span>
                </div>
            </div>
            
            <div style="text-align: center; margin-top: 30px;">
                <a href="/logout" class="btn" style="background: linear-gradient(135deg, #ff6b6b, #fa5252);">� Logout</a>
            </div>
        </div>
    </div>
</body>
</html>